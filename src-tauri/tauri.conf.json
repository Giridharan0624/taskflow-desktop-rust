{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskFlow",
  "version": "0.1.0",
  "identifier": "in.neurostack.taskflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TaskFlow",
        "width": 500,
        "height": 600,
        "minWidth": 450,
        "minHeight": 500,
        "maxWidth": 550,
        "maxHeight": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
