{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskFlow",
  "version": "0.1.4",
  "identifier": "in.neurostack.taskflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TaskFlow",
        "width": 500,
        "height": 600,
        "minWidth": 450,
        "minHeight": 500,
        "maxWidth": 550,
        "maxHeight": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "NeuroStack",
    "category": "Utility",
    "shortDescription": "Time tracker and activity monitor",
    "longDescription": "TaskFlow desktop companion — timer, activity counters, and screenshots.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "libx11-6",
          "libxi6",
          "libxtst6",
          "libxrandr2",
          "libxss1",
          "libxext6",
          "libxcb1",
          "libxcb-randr0",
          "libdbus-1-3",
          "libpipewire-0.3-0"
        ]
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  }
}
